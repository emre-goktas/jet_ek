# Gemini AI isimlendirme artık BYOK (Bring Your Own Key): her kullanıcı kendi
# anahtarını tarayıcıda saklar (localStorage) ve her istekte X-Gemini-Api-Key
# header'ı ile backend'e geçirir. Backend hiçbir anahtarı diske/DB'ye yazmaz,
# bu yüzden burada paylaşılan bir GEMINI_API_KEY artık gerekmiyor/kullanılmıyor.

# Faz 2 — Google Sign-In. REQUIRED: the app refuses to start unless both
# GOOGLE_CLIENT_ID and SESSION_SECRET_KEY below are set — authentication is
# mandatory, not optional.
# Create an OAuth Client ID (type "Web application") in Google Cloud Console >
# APIs & Services > Credentials, and add every origin you'll load the app from
# (e.g. http://127.0.0.1:7860 for local dev, your real domain for prod) under
# "Authorized JavaScript origins". No client secret is needed for this flow.
GOOGLE_CLIENT_ID=""

# Any long random string — signs the session cookie. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=""

# Set to "development" to allow the session cookie over plain HTTP (e.g.
# testing at http://127.0.0.1:7860). Leave unset/anything else in production —
# behind Cloudflare Tunnel the browser sees a real https:// origin, so the
# default (secure cookies) is what you want there.
JETEK_ENV=""
